<Window x:Class="WpfUI2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ thống Đăng ký học (MVVM)" Height="600" Width="850" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl>
            <TabItem Header="Quản lý Sinh viên">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Create Student" Grid.Row="0" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Text="{Binding NewStudentName, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="0,0,15,0" VerticalContentAlignment="Center"/>
                            <TextBlock Text="Class:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Text="{Binding NewStudentClass, UpdateSourceTrigger=PropertyChanged}" Width="100" Margin="0,0,15,0" VerticalContentAlignment="Center"/>
                            <Button Content="Create" Command="{Binding CreateStudentCommand}" Width="80" Background="#4CAF50" Foreground="White"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Show Student Details" Grid.Row="1" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Student ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding SearchStudentId, UpdateSourceTrigger=PropertyChanged}" Width="100" Margin="0,0,15,0" VerticalContentAlignment="Center"/>
                                <Button Content="Search" Command="{Binding SearchStudentCommand}" Width="80" Background="#2196F3" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="{Binding StudentDetailResult}" Foreground="Blue"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Show all Students" Grid.Row="2" Padding="10">
                        <DataGrid ItemsSource="{Binding Students}" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#f2f2f2"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Quản lý Khóa học">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Create Course" Grid.Row="0" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Name:" Width="50" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewCourseName, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,15,0"/>
                                <TextBlock Text="Credit:" Width="45" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewCourseCredit, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,0,15,0"/>
                                <TextBlock Text="Teacher:" Width="55" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewCourseTeacher, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,15,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Day (2-8):" Width="60" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewCourseDay, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,0,15,0"/>
                                <TextBlock Text="Max Size:" Width="60" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding NewCourseMax, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,0,15,0"/>
                                <Button Content="Create" Command="{Binding CreateCourseCommand}" Width="80" Background="#4CAF50" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Show all Courses" Grid.Row="1" Padding="10">
                        <DataGrid ItemsSource="{Binding Courses}" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#f2f2f2"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Quản lý Đăng ký">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <GroupBox Header="Register Course" Padding="10" Margin="0,0,10,0" Width="380">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Student ID:" Width="70" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding RegStudentId, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Course ID:" Width="70" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding RegCourseId, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                </StackPanel>
                                <Button Content="Register" Command="{Binding RegisterCourseCommand}" Width="100" HorizontalAlignment="Left" Background="#FF9800" Foreground="White"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Cancel Course" Padding="10" Width="380">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Registration ID:" Width="90" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding CancelRegId, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                </StackPanel>
                                <Button Content="Cancel Register" Command="{Binding CancelRegisterCommand}" Width="100" HorizontalAlignment="Left" Background="#F44336" Foreground="White"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <GroupBox Header="Show all Registrations (by Student ID)" Grid.Row="1" Padding="10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Student ID:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding ViewRegStudentId, UpdateSourceTrigger=PropertyChanged}" Width="100" Margin="0,0,15,0" VerticalContentAlignment="Center"/>
                                <Button Content="View Registrations" Command="{Binding ViewRegistrationsCommand}" Width="120" Background="#2196F3" Foreground="White"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Registrations}" AutoGenerateColumns="True" IsReadOnly="True" Height="250" AlternatingRowBackground="#f2f2f2"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>