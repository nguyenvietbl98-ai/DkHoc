@model IEnumerable<Domain.Core.Student>

@{
    ViewData["Title"] = "Students";
}

<h2>Students</h2>
<p><a class="btn btn-primary" href="/Students/Create">Create</a></p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Class</th>
            <th>Credit</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.Name</td>
                <td>@s.Class</td>
                <td>@s.Credit</td>
                <td>
                    <a class="btn btn-sm btn-secondary" href="/Students/Edit/@s.Id">Edit</a>
                    <form method="post" asp-action="Delete" asp-route-id="@s.Id" onsubmit="return confirm('Delete?');" style="display:inline-block;margin-left:6px;">
                        <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>