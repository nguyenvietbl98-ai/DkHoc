<h2 class="mt-4 mb-3">Thêm Khóa học</h2>
<div class="card shadow-sm" style="max-width: 600px;">
    <div class="card-body">
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
        <form method="post" action="/Course/Create">
            <div class="mb-3"><label>Tên khóa học:</label><input type="text" name="name" class="form-control" required /></div>
            <div class="row">
                <div class="col-md-6 mb-3"><label>Số tín chỉ (1-5):</label><input type="number" name="credit" class="form-control" required /></div>
                <div class="col-md-6 mb-3"><label>Giảng viên:</label><input type="text" name="teacher" class="form-control" required /></div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3"><label>Học vào Thứ (2-8):</label><input type="number" name="day" class="form-control" required /></div>
                <div class="col-md-6 mb-3"><label>Sĩ số tối đa:</label><input type="number" name="maxSize" class="form-control" required /></div>
            </div>
            <button type="submit" class="btn btn-primary">Tạo khóa học</button>
        </form>
    </div>
</div>