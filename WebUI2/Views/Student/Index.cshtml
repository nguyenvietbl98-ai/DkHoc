@model IEnumerable<Domain.Core.Student>
<h2 class="mt-4 mb-3">Danh sách Sinh viên</h2>
<a href="/Student/Create" class="btn btn-success mb-3">Thêm sinh viên mới</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên</th>
            <th>Lớp</th>
            <th>Tín chỉ</th>
            <th>Lịch học</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.Name</td>
                <td>@s.Class</td>
                <td><span class="badge bg-primary">@s.Credit / 15</span></td>
                <td>@(s.LichHoc.Any() ? "Thứ " + string.Join(", ", s.LichHoc) : "Chưa có lịch")</td>
            </tr>
        }
    </tbody>
</table>