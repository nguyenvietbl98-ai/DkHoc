@model IEnumerable<Domain.Core.Registration>
<h2 class="mt-4 mb-3">Quản lý Đăng ký môn học</h2>

<form method="get" action="/Registration/Index" class="d-flex mb-4" style="max-width: 400px;">
    <input type="number" name="studentId" value="@ViewBag.StudentId" class="form-control me-2" placeholder="Nhập ID Sinh viên..." required />
    <button type="submit" class="btn btn-primary">Xem Lịch sử</button>
</form>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (ViewBag.StudentId != null)
{
    <table class="table table-bordered text-center align-middle">
        <thead class="table-dark">
            <tr>
                <th>Mã Đăng ký (ID)</th>
                <th>Mã Khóa học</th>
                <th>Thời gian đăng ký</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="text-muted">Sinh viên này chưa đăng ký môn nào.</td></tr>
            }
            @foreach (var reg in Model)
            {
                <tr>
                    <td>@reg.Id</td>
                    <td class="fw-bold text-primary">@reg.CourseId</td>
                    <td>@reg.TimeDangKy.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <form method="post" action="/Registration/Cancel" onsubmit="return confirm('Bạn có chắc chắn muốn hủy môn học này?');">
                            <input type="hidden" name="registrationId" value="@reg.Id" />
                            <input type="hidden" name="studentId" value="@reg.StudentId" />
                            <button type="submit" class="btn btn-sm btn-danger">Hủy đăng ký</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}