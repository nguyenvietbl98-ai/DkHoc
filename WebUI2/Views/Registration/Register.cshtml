<h2 class="mt-4 mb-3">Đăng ký Môn học</h2>
<div class="card shadow-sm border-warning" style="max-width: 500px;">
    <div class="card-body">
        @Html.ValidationSummary(false, "", new { @class = "text-danger fw-bold" })
        <form method="post" action="/Registration/Register">
            <div class="mb-3">
                <label>ID Sinh viên:</label>
                <input type="number" name="studentId" class="form-control" required />
            </div>
            <div class="mb-3">
                <label>Mã Khóa học (Course ID):</label>
                <input type="text" name="courseId" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-warning text-dark fw-bold w-100">ĐĂNG KÝ NGAY</button>
        </form>
    </div>
</div>